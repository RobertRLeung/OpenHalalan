# Scraper run logs
*.log

# Superseded by data/Local_Election_Winners_2004_2025.csv
\[OLD\] NLE_Winners_2004_2025.csv

# Local working notes, not for publication
archive/

# Byte-identical duplicate of data/Local_Election_Winners_2004_2025.csv,
# which is the canonical tracked copy. Root-anchored so data/ is unaffected.
/Local_Election_Winners_2004_2025.csv

# Python
__pycache__/
*.py[cod]

# macOS
.DS_Store

# Uncompressed vote-counts build; the published artefact is the .csv.gz
data/processed/NLE_Vote_Counts_*.csv
data/output/NLE_Vote_Counts_*.csv

# Site payloads. These are generated by data/site/build_*.py and published on the
# gh-pages branch; the generators are the source of truth, not the output. Same rule
# explore.json has always followed. .geo_cache is the boundary download cache (16 MB).
data/site/*.json
data/site/*_report.txt
data/site/.geo_cache/
data/site/map_geo_prov/

# Re-fetchable raw source caches (large). The committed parsers regenerate the processed
# CSVs from these; the caches themselves are not published (188 MB of Wayback HTML, 27 MB
# of COMELEC PDFs). launch_assets/ holds local launch media, also not part of the dataset.
data/raw_data/rappler_2013/
data/raw_data/comelec_lec/
launch_assets/
data/raw_data/rappler_2010/
